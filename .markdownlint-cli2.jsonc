{
    "ignores": [
        ".venv",
        ".pytest_cache",
        "node_modules",
        ".next",
        ".git",
        "planning.md"
    ],
    "config": {
        "default": true,
        "line-length": false,
        "no-duplicate-heading": { "siblings_only": true },
        "table-column-style": false,
        // Makefile recipes require hard tabs; allow tabs inside code blocks
        "no-hard-tabs": { "code_blocks": false }
    }
}
